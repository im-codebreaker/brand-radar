{
  "name": "@stackit/api",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/under-pressure": "^9.0.3",
    "@stackit/auth": "workspace:*",
    "@stackit/cache": "workspace:*",
    "@stackit/db": "workspace:*",
    "@stackit/helpers": "workspace:*",
    "@stackit/types": "workspace:*",
    "@stackit/validations": "workspace:*",
    "better-auth": "^1.4.4",
    "close-with-grace": "^2.3.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^5.0.3",
    "pino-pretty": "^13.1.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@stackit/eslint-config": "workspace:*",
    "@stackit/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "fastify-tsconfig": "^3.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
