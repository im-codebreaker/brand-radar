{
  "name": "@stackit/db",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx --env-file-if-exists=../../.env prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.16.2",
    "@prisma/client": "^6.16.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@stackit/eslint-config": "workspace:*",
    "@stackit/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.10",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "prisma": "^6.16.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
