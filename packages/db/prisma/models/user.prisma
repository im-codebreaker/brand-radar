model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // BETTER_AUTH_RELATIONS_START — removed by `pnpm setup` if auth declined
  sessions Session[]
  accounts Account[]
  // BETTER_AUTH_RELATIONS_END

  @@map("users")
}
